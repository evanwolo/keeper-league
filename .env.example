# ── Required ─────────────────────────────────────────────────────────────────

# Your Fantrax league ID (found in your league URL or API docs)
FANTRAX_LEAGUE_ID=mg9m448k

# ── Required for live data ────────────────────────────────────────────────────

# Fantrax session cookie — ALL Fantrax API calls require this.
# To get it:
#   1. Log in to fantrax.com in Chrome/Edge
#   2. Open DevTools (F12) → Network tab
#   3. Click any page in your league
#   4. Find a request to www.fantrax.com, click it
#   5. Under "Request Headers", copy the full Cookie value
#   6. Paste it below (keep it on one line)
FANTRAX_COOKIE=

# HTTP server port (default: 3000)
PORT=3000

# ── Cron Schedules ───────────────────────────────────────────────────────────
# See https://crontab.guru for syntax help
# All values below are the defaults if not set.

# Rosters, players, league info — every 15 minutes
CRON_ROSTERS=*/15 * * * *

# Standings / real stats — every 30 minutes
CRON_STANDINGS=*/30 * * * *

# FanGraphs projections (all types) — twice daily at midnight and noon
CRON_PROJECTIONS=0 0,12 * * *

# Draft picks & results — every hour
CRON_DRAFT=0 * * * *

# ADP data — daily at 6 AM
CRON_ADP=0 6 * * *

# Power rankings (blended projections + real stats) — daily at 11 PM
CRON_RANKINGS=0 23 * * *

# ── Projection Types ────────────────────────────────────────────────────────
# Comma-separated list of FanGraphs projection systems to fetch
PROJECTION_TYPES=steamer,zips,atc,thebat,thebatx,dc
